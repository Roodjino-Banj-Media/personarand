# Anthropic (already set up — Opus 4.7 for content generation)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (email provider — already set up)
RESEND_API_KEY=re_...
[email protected]
RESEND_FROM_NAME=Roodjino Chérilus

# Supabase — get these from your Supabase project at supabase.com/dashboard
# Settings → Database → Connection String (Transaction mode, 6543 or Session mode, 5432)
DATABASE_URL=postgresql://postgres.PROJECT_REF:[email protected]:5432/postgres

# Settings → API
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...   # server-only, keep secret
# Also expose these to the client (Vite reads VITE_ prefixed vars)
VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...      # safe to expose to browser

# Access control — comma-separated emails allowed to log in.
# Set this to at least your own email before deploying.
[email protected]

# Cron shared secret — set a random string. Used by GitHub Actions to hit /api/cron.
CRON_SECRET=random-long-string-here

# Public URL of the deployed app (used in unsubscribe links + tracking pixels)
PUBLIC_BASE_URL=https://pbroodjino.banjmedia.com

# Optional: Resend webhook signing secret
RESEND_WEBHOOK_SECRET=

# Local dev only (ignored in production)
SERVER_PORT=3001
